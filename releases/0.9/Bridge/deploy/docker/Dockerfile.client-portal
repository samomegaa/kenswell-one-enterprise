FROM node:20-alpine AS build

WORKDIR /app

COPY releases/0.9/Bridge/apps/client-portal/package*.json ./
RUN npm ci

COPY releases/0.9/Bridge/apps/client-portal ./
RUN npm run build

FROM nginx:1.27-alpine AS runtime

COPY --from=build /app/dist /usr/share/nginx/html
COPY releases/0.9/Bridge/deploy/docker/nginx.client-portal.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
